# Environment Variables for Old Oak Town
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to git!

# Server Configuration
PORT=3000
NODE_ENV=development
SITE_URL=https://www.oldoaktown.co.uk

# Stripe Configuration
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Supabase Configuration
# Get these from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Anthropic (Claude API)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Beehiiv Newsletter
# Get from https://app.beehiiv.com/settings/integrations
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=pub_YOUR_PUBLICATION_ID_HERE

# Admin Authentication
# ADMIN_TOKEN is used in email approval links — keep this secret and long
ADMIN_TOKEN=generate_a_long_random_secret_here
# ADMIN_PASSWORD is used for the /api/get-pending admin dashboard
ADMIN_PASSWORD=your_secure_password_here

# Email Configuration (for nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
ADMIN_EMAIL=admin@oldoaktown.co.uk
