# Environment Variables for Old Oak Town
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to git!

# Server Configuration
PORT=3000
NODE_ENV=development
SITE_URL=https://www.oldoaktown.co.uk

# Stripe Configuration
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Supabase Configuration
# Get these from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Anthropic (Claude API)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Beehiiv Newsletter
# Get from https://app.beehiiv.com/settings/integrations
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=pub_YOUR_PUBLICATION_ID_HERE

# Admin Authentication
# ADMIN_TOKEN is used in email approval links — keep this secret and long
ADMIN_TOKEN=generate_a_long_random_secret_here
# ADMIN_PASSWORD is used for the /api/get-pending admin dashboard
ADMIN_PASSWORD=your_secure_password_here

# Transactional Email (Resend — used for approval/cancellation notifications)
# Get an API key from https://resend.com/api-keys after verifying the
# oldoaktown.co.uk domain in your Resend account.
RESEND_API_KEY=re_YOUR_KEY_HERE
RESEND_FROM_EMAIL=Old Oak Town <notifications@oldoaktown.co.uk>
ADMIN_EMAIL=admin@oldoaktown.co.uk

# Instagram Live Feed (homepage "Latest from @oldoaktown" grid)
# Long-lived access token from the Instagram API with Instagram Login
# (Business/Creator account). The old Basic Display API was retired by Meta
# in Dec 2024, so this uses graph.instagram.com/me/media.
# Setup:
#   1. Create a Meta app at https://developers.facebook.com/apps
#   2. Add the Instagram product and connect the @oldoaktown Business account
#   3. Generate a long-lived token (scope: instagram_business_basic)
# Tokens last ~60 days — refresh via graph.instagram.com/refresh_access_token.
# If unset, the homepage falls back to its static Instagram grid (no error).
INSTAGRAM_ACCESS_TOKEN=

# Legacy email config (still used by scripts/ and netlify/functions/ — not
# by api/submit-business.js or api/stripe-webhook.js, which use Resend above)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
