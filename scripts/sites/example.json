{
  "_comment": "Copy this file to scripts/sites/mysite.json and fill it in. Then run:",
  "_command": "node scripts/generate-social-agent.js --config scripts/sites/mysite.json --output ../mysite/social-agent.html",

  "siteName":   "My Site Name",
  "siteSlug":   "mysite",
  "iconLetter": "M",

  "colors": {
    "primary":    "#1C3A0E",
    "primaryMid": "#2F6020",
    "accent":     "#4C8A35",
    "accentPale": "#D4E8C8",
    "ghost":      "#F0F7EB",
    "border":     "#DDE8D4",
    "muted":      "#6B7B5E",
    "ink":        "#0F1A0A",
    "cream":      "#FAF8F4"
  },

  "fonts": {
    "heading":       "Instrument Serif",
    "body":          "DM Sans",
    "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
  },

  "passwordHash": "",

  "platforms": [
    { "id": "facebook",  "label": "Facebook",  "emoji": "📘", "css": "fb", "color": "#1877F2", "bg": "#E7F0FD", "charLimit": 63206, "requiresMedia": false, "defaultTime": "9:00am"  },
    { "id": "instagram", "label": "Instagram", "emoji": "📸", "css": "ig", "color": "#C13584", "bg": "#FEE9F3", "charLimit": 2200,  "requiresMedia": true,  "defaultTime": "11:00am" },
    { "id": "linkedin",  "label": "LinkedIn",  "emoji": "💼", "css": "li", "color": "#0A66C2", "bg": "#E8F0FA", "charLimit": 1248,  "requiresMedia": false, "defaultTime": "8:00am"  }
  ],

  "_platformOptions": {
    "_comment": "Add any of these to the platforms array above. Set BUFFER_CHANNEL_<PLATFORM_ID_UPPER> env var for each.",
    "twitter":   { "id": "twitter",   "label": "Twitter / X", "emoji": "🐦", "css": "tw", "color": "#000000", "bg": "#E8E8E8", "charLimit": 280,  "requiresMedia": false, "defaultTime": "10:00am" },
    "tiktok":    { "id": "tiktok",    "label": "TikTok",      "emoji": "🎵", "css": "tt", "color": "#010101", "bg": "#EAEAEA", "charLimit": 2200, "requiresMedia": true,  "defaultTime": "7:00pm"  },
    "pinterest": { "id": "pinterest", "label": "Pinterest",   "emoji": "📌", "css": "pn", "color": "#E60023", "bg": "#FDECEA", "charLimit": 500,  "requiresMedia": true,  "defaultTime": "2:00pm"  },
    "youtube":   { "id": "youtube",   "label": "YouTube",     "emoji": "▶️",  "css": "yt", "color": "#FF0000", "bg": "#FFEEEE", "charLimit": 5000, "requiresMedia": true,  "defaultTime": "3:00pm"  }
  },

  "researchSources": [
    { "type": "custom",  "emoji": "📰", "label": "Latest news",        "defaultOn": true  },
    { "type": "custom",  "emoji": "📅", "label": "Events & calendar",  "defaultOn": true  },
    { "type": "custom",  "emoji": "💼", "label": "Business spotlights", "defaultOn": true  },
    { "type": "website", "emoji": "🌐", "label": "Our website",        "url": "https://example.com", "defaultOn": true  },
    { "type": "google",  "emoji": "🔍", "label": "Google News",        "keyword": "your topic here", "defaultOn": false },
    { "type": "rss",     "emoji": "📡", "label": "Industry RSS feed",  "url": "https://example.com/feed", "defaultOn": false }
  ],

  "themePlaceholder": "Weekly theme or focus…",

  "idleDescription": "Enter your weekly theme, toggle your research sources, then hit Research & Draft. Approved posts go directly to Buffer.",

  "pipelineLogs": [
    "> Initialising research pipeline…",
    "> Searching: latest news…",
    "> Fetching: site content…",
    "> Searching: community updates…",
    "> Research complete. Passing to drafting engine…"
  ]
}
