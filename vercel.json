{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "functions": {
    "api/generate-posts.js": {
      "maxDuration": 60
    },
    "api/buffer-post.js": {
      "maxDuration": 30
    }
  }
}
