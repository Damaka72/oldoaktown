{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/approve-business", "destination": "/api/approve?kind=business" },
    { "source": "/api/approve-event", "destination": "/api/approve?kind=event" },
    { "source": "/api/approve-listing", "destination": "/api/approve?kind=listing" },
    { "source": "/api/instagram-feed", "destination": "/api/videos?ig=1" }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "functions": {
    "api/generate-posts.js": {
      "maxDuration": 60
    },
    "api/buffer-post.js": {
      "maxDuration": 30
    }
  }
}
